# Sul server: copia come .env.production (accanto a package.json).
# Schema come le altre app sullo stesso Plesk (es. contenthunter): DATABASE_URL + NODE_ENV.
#
# Opzione A — una sola stringa (preferita, come nell'app di riferimento):
#   mysql://UTENTE:PASSWORD@HOST:PORTA_DB/NOME_DB
# Esempio locale al server:
# DATABASE_URL=mysql://admin_handy_2026:LA_TUA_PASSWORD@127.0.0.1:3301/handy_db
#
# Opzione B — variabili separate (se non usi DATABASE_URL):
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3301
# MYSQL_USER=admin_handy_2026
# MYSQL_PASSWORD=
# MYSQL_DATABASE=handy_db
#
# Porta HTTP Node: di solito la imposta Plesk (PORT). Stessa porta = proxy nginx.
# PORT=3000

NODE_ENV=production

# Sostituisci USER, PASSWORD e adatta host/porta/db:
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3301/handy_db
